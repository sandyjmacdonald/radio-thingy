# Required: paths
db_path            = "/home/radio/deadair/radio.db"
station_tomls_glob = "/home/radio/deadair/stations/*.toml"
noise_file         = "/home/radio/media/effects/noise.mp3"

# Audio output
audio_device = "pipewire"   # run WITHOUT sudo
master_vol   = 60           # global master, 0–100

# Optional radio "processing" — remove or comment out for raw audio
radio_af = "lavfi=[highpass=f=25,lowpass=f=15000,acompressor=threshold=-24dB:ratio=2.5:attack=20:release=250:makeup=5:knee=8dB,alimiter=limit=0.98]"

# Dial behaviour
freq_min    = 88.0
freq_max    = 98.0
step        = 0.1    # MHz per button press
lock_window = 0.2    # MHz from station centre → full volume
fade_window = 0.5    # MHz fade zone outside lock_window

# Overlay (voice-over) defaults — applied globally to all stations
overlay_pad_s  = 2.0   # seconds into song before overlay fires
overlay_duck   = 0.65  # music volume factor while overlay plays (0.0–1.0)
overlay_ramp_s = 0.5   # duck fade in/out duration (seconds)

# Hardware — tuning LED (optional)
# Connect a PWM LED to any BCM GPIO pin. The LED fades in as the dial
# approaches a station, reaching full brightness when locked on.
# Remove or comment out tuning_led_pin to disable.
# tuning_led_pin = 17     # BCM GPIO pin
# led_brightness = 0.5    # maximum PWM brightness (0.0–1.0)

# Hardware — buttons (optional)
# Each entry specifies a BCM GPIO pin and the RadioApp method to call on press.
# Available actions: tune_next_station, toggle_mute
# buttons = [
#     { pin = 23, action = "tune_next_station" },   # cycle to the next station
#     { pin = 24, action = "toggle_mute" },          # mute / unmute
# ]

# Hardware — rotary encoder (RGB Encoder Breakout, I2C addr 0x0F)
# encoder_i2c_bus       = 1   # I2C bus (1 = pins 3/5, 0 = pins 27/28)
# encoder_interrupt_pin = 4   # BCM GPIO pin wired to INT header (omit to poll instead)

# Hardware — potentiometer (Potentiometer Breakout, I2C addr 0x0E)
# potentiometer         = false  # set to true to enable potentiometer volume control
# potentiometer_i2c_bus = 0      # I2C bus (0 = pins 27/28, 1 = pins 3/5)

# Main loop
tick_s = 0.25

# HTTP API
api_host = "0.0.0.0"
api_port = 8000
